PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/trfc_db

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_key_here_change_in_production

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# M-Pesa Configuration
# Get these from https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key_from_daraja
MPESA_CONSUMER_SECRET=your_consumer_secret_from_daraja
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd1a2c2f2f
# Must be publicly accessible for production
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback
# Options: sandbox or production
MPESA_ENV=sandbox

# Paystack (event tickets)
# Get these from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxx

# Email Configuration
EMAIL_USER=
EMAIL_PASS=

# Africa's Talking (SMS)
AT_API_KEY=
AT_USERNAME=sandbox

# Database migrations (run on existing DBs after schema changes):
# psql $DATABASE_URL -f server/migrations/001_guest_commerce.sql
# psql $DATABASE_URL -f server/migrations/002_ticket_batches.sql
# psql $DATABASE_URL -f server/migrations/007_ticket_paystack.sql

# Application Environment
NODE_ENV=development
API_BASE_URL=http://localhost:5000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/trfc_db

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production

# M-Pesa Configuration (canonical — used by server/src/config/env.ts)
# Get these from https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key_from_daraja
MPESA_CONSUMER_SECRET=your_consumer_secret_from_daraja
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd1a2c2f2f
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback
MPESA_ENV=sandbox

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# Email Configuration (Gmail app password)
# Prefer EMAIL_PASSWORD; EMAIL_PASS is also accepted by the server.
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
# EMAIL_PASS=your_app_password
FRONTEND_URL=https://trfc-website-d41f18cf654e.herokuapp.com
CONTACT_EMAIL=thikaroadfitness@gmail.com
CONTACT_PHONE=+254 762 550214

# Logging
LOG_LEVEL=debug

# Features
ENABLE_PAYMENTS=true
ENABLE_EMAIL=true
ENABLE_CLOUDINARY=false

# Public site contact (client — prefix with VITE_)
VITE_CONTACT_EMAIL=thikaroadfitness@gmail.com
VITE_CONTACT_PHONE=+254 762 550214
